# --- Mining (GitHub) ---
# A READ-ONLY GitHub token, used only to read PR review comments and diffs.
# Least privilege: a fine-grained token with "Pull requests: Read" + "Contents: Read"
# on the target repos is sufficient. Never grant write/admin scopes for mining.
GITHUB_TOKEN=ghp_your_read_only_token_here

# Optional GitHub Enterprise base URL (omit for github.com)
# GITHUB_API_URL=https://github.your-company.com/api/v3

# --- Optional headless distillation model (CI only) ---
# The MCP server runs NO model. These are ONLY for `dna distill --model ...`
# in unattended CI, and should be the team's OWN model — never a bundled third party.
#
# Ollama (local):
# DNA_MODEL=ollama:llama3.1
# DNA_MODEL_BASE_URL=http://localhost:11434
#
# OpenAI-compatible API (the team's own key):
# DNA_MODEL=openai:gpt-4o-mini
# DNA_MODEL_BASE_URL=https://api.openai.com/v1
# DNA_MODEL_API_KEY=sk-...
